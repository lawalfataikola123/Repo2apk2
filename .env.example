# ════════════════════════════════════════════════════════════════════
# Repo2APK - Production Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
# ════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Your domain or IP address (no trailing slash)
CLIENT_URL=https://yourdomain.com

# ─── Security (REQUIRED - generate strong random strings) ────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Generate with: openssl rand -base64 64
API_KEY_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING

# ─── Build Configuration ──────────────────────────────────────────────────────
BUILD_TIMEOUT_MS=900000        # 15 minutes
MAX_REPO_SIZE_MB=500           # Max repo size before rejection

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # debug | info | warn | error
